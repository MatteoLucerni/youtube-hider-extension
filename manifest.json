{
    "manifest_version": 3,
    "name": "Youtube Hider: hide watched videos, Shorts and low views",
    "short_name": "YouTube Hider",
    "version": "3.1.3",
    "description": "Hides already watched videos from YouTube, as well as low views videos and remove Shorts.",
    "icons": {
        "16": "assets/icons/YT Hider icon v6.png",
        "48": "assets/icons/YT Hider icon v6.png",
        "128": "assets/icons/YT Hider icon v6.png"
    },
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*"
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "assets/icons/youtube-hider-logo.png",
                "assets/icons/youtube-hider-logo-light.png",
                "popup/popup.html"
            ],
            "matches": [
                "https://www.youtube.com/*",
                "https://m.youtube.com/*"
            ]
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/*",
                "https://m.youtube.com/*"
            ],
            "js": [
                "content/page-bridge.js"
            ],
            "run_at": "document_start",
            "world": "MAIN"
        },
        {
            "matches": [
                "https://www.youtube.com/*",
                "https://m.youtube.com/*"
            ],
            "js": [
                "content/env.js",
                "content/utils.js",
                "content/whitelist-utils.js",
                "content/state.js",
                "content/warning.js",
                "content/header-button.js",
                "content/tutorial.js",
                "content/parsers.js",
                "content/filters.js",
                "content/channel-whitelist-button.js",
                "content/channel-blacklist-button.js",
                "content/init.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": "assets/icons/YT Hider icon v6.png"
    }
}